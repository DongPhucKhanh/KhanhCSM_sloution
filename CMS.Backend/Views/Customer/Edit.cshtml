@model CMS.Data.Entities.Customer

@{
    ViewData["Title"] = "Sửa khách hàng";
}

<h2 class="text-warning my-3 fw-bold">CHỈNH SỬA THÔNG TIN KHÁCH HÀNG</h2>
<hr />

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Edit">
            <input type="hidden" asp-for="Id" />

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Họ và tên</label>
                    <input asp-for="FullName" class="form-control" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Số điện thoại</label>
                    <input asp-for="Phone" class="form-control" required />
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Email</label>
                    <input asp-for="Email" type="email" class="form-control" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Mật khẩu</label>
                    <input asp-for="Password" type="password" class="form-control" value="@Model.Password" required />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Địa chỉ</label>
                <input asp-for="Address" class="form-control" />
            </div>

            <div class="mt-3 border-top pt-3">
                <button type="submit" class="btn btn-warning px-4 fw-bold text-dark">Cập nhật</button>
                <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
            </div>
        </form>
    </div>
</div>