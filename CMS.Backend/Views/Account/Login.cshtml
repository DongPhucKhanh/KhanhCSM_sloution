@* version:1.0 *@
@{
    Layout = null; // Trang đăng nhập độc lập, không dùng chung sidebar layout hệ thống [cite: 1776]
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập hệ thống - CMS Admin Panel</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />

    <style>
        body {
            /* Nền chuyển màu Gradient từ tối sang xanh sâu sang trọng */
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #0f172a 100%);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            position: relative;
        }

        /* Tạo hai khối cầu mờ trang trí phía sau card tạo hiệu ứng chiều sâu */
        body::before, body::after {
            content: "";
            position: absolute;
            width: 300px;
            height: 300px;
            border-radius: 50%;
            background: linear-gradient(45deg, #3b82f6, #8b5cf6);
            filter: blur(80px);
            opacity: 0.15;
            z-index: 0;
        }
        body::before { top: -50px; left: -50px; }
        body::after { bottom: -50px; right: -50px; }

        .login-container {
            position: relative;
            z-index: 1;
            width: 100%;
            max-width: 420px;
            padding: 15px;
        }

        .login-card {
            background: rgba(30, 41, 59, 0.7);
            backdrop-filter: blur(10px); /* Hiệu ứng kính mờ thời thượng */
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 16px;
            padding: 40px 30px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
        }

        .login-header h3 {
            color: #ffffff;
            font-size: 24px;
            letter-spacing: 0.5px;
        }

        .login-header p {
            color: #94a3b8;
            font-size: 14px;
        }

        .form-label {
            color: #cbd5e1;
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 8px;
            text-uppercase: uppercase;
            letter-spacing: 0.5px;
        }

        .input-group-custom {
            position: relative;
            margin-bottom: 22px;
        }

        .input-group-custom i {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: #64748b;
            transition: color 0.3s ease;
            z-index: 10;
        }

        .input-group-custom .form-control {
            background-color: #0f172a !important;
            border: 1px solid #334155;
            color: #ffffff !important;
            padding: 12px 15px 12px 45px;
            border-radius: 10px;
            font-size: 15px;
            transition: all 0.3s ease;
        }

        /* Hiệu ứng khi nhấn chuột vào ô nhập liệu */
        .input-group-custom .form-control:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.2);
            outline: none;
        }

        .input-group-custom .form-control:focus + i {
            color: #3b82f6; /* Đổi màu icon khi focus */
        }

        .btn-login {
            background: linear-gradient(90deg, #3b82f6 0%, #2563eb 100%);
            border: none;
            color: #ffffff;
            padding: 12px;
            border-radius: 10px;
            font-size: 16px;
            font-weight: 600;
            letter-spacing: 0.5px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3);
        }

        .btn-login:hover {
            background: linear-gradient(90deg, #2563eb 0%, #1d4ed8 100%);
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(37, 99, 235, 0.4);
        }

        .btn-login:active {
            transform: translateY(1px);
        }

        .alert-custom {
            background-color: rgba(239, 68, 68, 0.15);
            border: 1px solid rgba(239, 68, 68, 0.3);
            color: #fca5a5;
            border-radius: 10px;
            font-size: 13px;
            padding: 10px;
            margin-bottom: 20px;
        }
    </style>
</head>
<body>

    <div class="login-container">
        <div class="login-card">

            <div class="login-header text-center mb-4">
                <div class="mb-3 d-inline-block text-primary" style="font-size: 40px;">
                    <i class="fas fa-shield-alt"></i>
                </div>
                <h3 class="fw-bold mb-1">HỆ THỐNG QUẢN TRỊ CMS</h3>
                <p>Vui lòng đăng nhập để tiếp tục</p>
            </div>

            <form asp-action="Login" method="post">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label class="form-label">Tên đăng nhập</label>
                    <div class="input-group-custom">
                        <input type="text" name="username" class="form-control" placeholder="Nhập tài khoản của bạn..." autocomplete="off" required />
                        <i class="fas fa-user"></i>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Mật khẩu</label>
                    <div class="input-group-custom">
                        <input type="password" name="password" class="form-control" placeholder="Nhập mật khẩu kiểm tra..." required />
                        <i class="fas fa-lock"></i>
                    </div>
                </div>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-custom text-center mb-3 animate__animated animate__headShake">
                        <i class="fas fa-exclamation-circle me-1"></i> @ViewBag.Error
                    </div>
                }

                <button type="submit" class="btn btn-login w-100 mt-2">
                    <i class="fas fa-sign-in-alt me-2"></i> ĐĂNG NHẬP HỆ THỐNG
                </button>
            </form>

        </div>
    </div>

</body>
</html>