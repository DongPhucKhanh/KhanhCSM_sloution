@* Buổi 5 - Phần B - Bước 3: Giao diện báo lỗi 403 Từ chối truy cập *@
@{
    Layout = "_Layout"; // Giữ lại khung sườn Sidebar Admin để họ bấm chọn chức năng khác
    ViewData["Title"] = "Không có quyền truy cập";
}

<div class="container mt-5 text-center">
    <div class="card p-5 shadow-sm border-0" style="max-width: 600px; margin: 0 auto;">
        <div class="card-body">
            <div class="text-danger mb-4" style="font-size: 60px;">
                <i class="fas fa-exclamation-triangle"></i>
            </div>

            <h2 class="text-danger fw-bold mb-3">403 - TỪ CHỐI TRUY CẬP</h2>

            <p class="text-muted fs-5">
                Tài khoản của bạn không có đặc quyền <strong>Quản trị viên (Admin)</strong> để truy cập vào phân hệ quản lý thành viên này.
            </p>

            <p class="small text-secondary mb-4">
                Vui lòng liên hệ với Quản trị viên tối cao để được cấp thêm quyền nếu đây là một sự nhầm lẫn.
            </p>

            <div class="d-grid gap-2 d-md-block">
                <a href="/" class="btn btn-primary px-4 fw-bold me-md-2">
                    <i class="fas fa-home me-1"></i> Quay lại Trang chủ
                </a>
                <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger px-4 fw-bold">
                    <i class="fas fa-sign-out-alt me-1"></i> Đăng nhập tài khoản khác
                </a>
            </div>
        </div>
    </div>
</div>