@model CMS.Data.Entities.Post

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <a href="/Post" class="btn btn-secondary btn-sm mb-3">← Quay lại danh sách</a>
            <div class="card shadow">
                <img src="@Model.ImageUrl" class="card-img-top" alt="Cover Image">
                <div class="card-body">
                    <h1 class="card-title text-danger fw-bold">@Model.Title</h1>
                    <p class="text-muted small">Ngày đăng: @Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")</p>
                    <hr />
                    <p class="card-text fs-5" style="line-height: 1.8;">@Model.Content</p>
                </div>
            </div>
        </div>
    </div>
</div>