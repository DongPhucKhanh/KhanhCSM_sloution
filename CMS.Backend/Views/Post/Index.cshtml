@model IEnumerable<CMS.Data.Entities.Post>

<div class="container mt-4">
    <h2 class="mb-4 text-danger text-center fw-bold">DANH SÁCH BÀI VIẾT MỚI NHẤT</h2>
    <div class="row">
        @if (Model != null)
        {
            foreach (var item in Model)
            {
                <div class="col-md-4 mb-3">
                    <div class="card shadow-sm h-100">
                        <img src="@item.ImageUrl" class="card-img-top" alt="Thumbnail">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title text-primary fw-bold">@item.Title</h5>
                            <p class="card-text text-truncate">@item.Content</p>
                            <p class="text-muted small mt-auto">Ngày đăng: @item.CreatedDate.ToString("dd/MM/yyyy")</p>
                            <a href="/Post/Details/@item.Id" class="btn btn-outline-primary btn-sm mt-2">Xem chi tiết</a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>