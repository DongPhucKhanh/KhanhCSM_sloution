@model IEnumerable<CMS.Data.Entities.Post>

<div class="d-flex justify-content-between align-items-center my-3">
    <h2 class="text-primary m-0">QUẢN LÝ BÀI VIẾT</h2>
    <a asp-action="Create" class="btn btn-success">Viết bài mới</a>
</div>

<table class="table table-bordered table-striped align-middle">
    <thead>
        <tr class="table-dark">
            <th style="width: 50px;">ID</th>
            <th style="width: 100px;">Hình ảnh</th>
            <th>Tiêu đề bài viết</th>
            <th>Ngày tạo</th>
            <th class="text-center" style="width: 200px;">Chức năng</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>
                    <img src="@item.ImageUrl" alt="Thumbnail" class="img-thumbnail" style="max-height: 60px; object-fit: cover;" />
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="fw-bold text-decoration-none text-info">@item.Title</a>
                </td>
                <td class="small text-muted">@item.CreatedDate.ToString("dd/MM/yyyy")</td>
                <td class="text-center">
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm text-white">Xem</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Sửa</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm"
                       onclick="return confirm('Bạn có chắc chắn muốn xóa bài viết này không?')">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>