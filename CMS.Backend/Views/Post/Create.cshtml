@model CMS.Data.Entities.Post
@{
    ViewData["Title"] = "Thêm bài viết mới";
}

<h2 class="text-primary my-3 fw-bold">VIẾT BÀI MỚI</h2>
<hr />

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div class="row">
                <div class="col-md-8 mb-3">
                    <label class="form-label fw-bold">Tiêu đề bài viết</label>
                    <input asp-for="Title" class="form-control" placeholder="Nhập tiêu đề..." required />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold">Thuộc danh mục bài viết</label>
                    <select asp-for="CategoryId" class="form-select" required>
                        <option value="">-- Chọn danh mục --</option>
                        @if (ViewBag.Categories != null)
                        {
                            foreach (var cat in ViewBag.Categories)
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Hình ảnh đại diện bài viết (Chọn file từ máy tính)</label>
                <input type="file" name="ImageFile" class="form-control" accept="image/*" />
                <small class="text-muted">Hỗ trợ các định dạng tệp ảnh: .jpg, .png, .jpeg, .webp</small>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Nội dung chi tiết bài viết <span class="badge bg-success">CKEditor 5</span></label>
                <textarea asp-for="Content" id="ContentEditor" class="form-control" rows="10" required></textarea>
                <span asp-validation-for="Content" class="text-danger small"></span>
            </div>

            <div class="mt-3 border-top pt-3">
                <button type="submit" class="btn btn-primary px-4 fw-bold">Đăng bài viết</button>
                <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <!-- Tải CKEditor 5 từ CDN -->
    <script src="https://cdn.ckeditor.com/ckeditor5/41.4.2/classic/ckeditor.js"></script>
    <script>
        // Khởi tạo CKEditor 5 trên textarea có id="ContentEditor"
        ClassicEditor
            .create(document.querySelector('#ContentEditor'), {
                // Cấu hình upload ảnh trực tiếp qua Simple Upload Adapter
                simpleUpload: {
                    // Địa chỉ API backend nhận file ảnh
                    uploadUrl: '/api/Upload/Image',
                    // Gửi kèm cookie để xác thực [Authorize] ở backend
                    withCredentials: true,
                    headers: {
                        // Gửi token chống giả mạo (CSRF) nếu cần
                        'X-CSRF-TOKEN': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                    }
                },
                toolbar: {
                    items: [
                        'heading', '|',
                        'bold', 'italic', 'underline', 'strikethrough', '|',
                        'link', 'uploadImage', 'insertTable', 'blockQuote', '|',
                        'bulletedList', 'numberedList', 'outdent', 'indent', '|',
                        'alignment', '|',
                        'fontSize', 'fontColor', 'fontBackgroundColor', '|',
                        'undo', 'redo'
                    ]
                },
                language: 'vi'
            })
            .then(editor => {
                // Đồng bộ nội dung CKEditor vào textarea gốc khi submit form
                editor.model.document.on('change:data', () => {
                    document.querySelector('#ContentEditor').value = editor.getData();
                });
                // Trước khi submit: cập nhật lại một lần cuối
                document.querySelector('form').addEventListener('submit', () => {
                    document.querySelector('#ContentEditor').value = editor.getData();
                });
            })
            .catch(error => {
                console.error('Lỗi khởi tạo CKEditor:', error);
            });
    </script>
}