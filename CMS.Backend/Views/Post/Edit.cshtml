@model CMS.Data.Entities.Post
@{
    ViewData["Title"] = "Chỉnh sửa bài viết";
}

<h2 class="text-warning my-3 fw-bold"><i class="fas fa-edit me-2"></i>CHỈNH SỬA BÀI VIẾT</h2>
<hr />

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedDate" />

            <div asp-validation-summary="All" class="text-danger small fw-bold mb-3"></div>

            <div class="row">
                <div class="col-md-8 mb-3">
                    <label class="form-label fw-bold">Tiêu đề bài viết</label>
                    <input asp-for="Title" class="form-control" placeholder="Nhập tiêu đề..." required />
                    <span asp-validation-for="Title" class="text-danger small fw-bold"></span>
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold">Thuộc danh mục bài viết</label>
                    <select asp-for="CategoryId" class="form-select" required>
                        @if (ViewBag.Categories != null)
                        {
                            foreach (var cat in ViewBag.Categories)
                            {
                                if (cat.Id == Model.CategoryId)
                                {
                                    <option value="@cat.Id" selected="selected">@cat.Name</option>
                                }
                                else
                                {
                                    <option value="@cat.Id">@cat.Name</option>
                                }
                            }
                        }
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger small fw-bold"></span>
                </div>
            </div>

            <div class="row mb-3 align-items-center">
                <div class="col-md-9">
                    <label class="form-label fw-bold">Chọn file ảnh thay thế mới (Nếu muốn đổi)</label>
                    <input type="file" name="ImageFile" class="form-control" accept="image/*" />
                    <small class="text-muted">Để trống ô này nếu Khoa muốn giữ nguyên ảnh đại diện cũ.</small>
                </div>
                <div class="col-md-3 text-center">
                    <label class="form-label d-block small text-muted fw-bold">Ảnh hiện tại</label>
                    <img src="@Model.ImageUrl" class="img-thumbnail" style="max-height: 90px; object-fit: cover;" onerror="this.src='https://via.placeholder.com/150'" />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Nội dung chi tiết bài viết</label>
                <textarea asp-for="Content" class="form-control" rows="8" required></textarea>
                <span asp-validation-for="Content" class="text-danger small fw-bold"></span>
            </div>

            <div class="mt-3 border-top pt-3">
                <button type="submit" class="btn btn-warning px-4 fw-bold text-dark">
                    <i class="fas fa-save me-1"></i> Cập nhật bài viết
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-left me-1"></i> Quay lại
                </a>
            </div>
        </form>
    </div>
</div>