@* Họ và tên: Đồng Phúc Khánh - MSSV: 2123110051
   Chức năng: Giao diện Quản lý Sản phẩm tích hợp Thanh Tìm Kiếm, Lọc Danh Mục và Phân Trang
*@
@model IEnumerable<CMS.Data.Entities.Product>

@{
    ViewData["Title"] = "Quản lý sản phẩm";
}

<div class="card shadow-sm mt-3">
    <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
        <h4 class="text-success fw-bold m-0">
            <i class="fas fa-cubes me-2"></i>QUẢN LÝ DANH SÁCH SẢN PHẨM
        </h4>
        <a asp-action="Create" class="btn btn-success btn-sm fw-bold">
            <i class="fas fa-plus-circle me-1"></i>THÊM SẢN PHẨM MỚI
        </a>
    </div>

    <div class="card-body bg-light border-bottom py-3">
        <form asp-action="Index" method="get" class="row g-2 align-items-center">

            <div class="col-md-4">
                <input type="text" name="searchString" value="@ViewBag.CurrentSearch" class="form-control" placeholder="Nhập tên sản phẩm cần tìm..." />
            </div>

            <div class="col-md-4">
                <select name="categoryProductId" class="form-select">
                    <option value="">-- Tất cả danh mục --</option>
                    @* Vòng lặp in ra các danh mục từ ViewBag *@
                    @if (ViewBag.CategoryProducts != null)
                    {
                        foreach (var cat in ViewBag.CategoryProducts)
                        {
                            // Kiểm tra nếu danh mục này đang được chọn thì thêm thuộc tính selected
                            if (ViewBag.CurrentCategory != null && ViewBag.CurrentCategory == cat.Id)
                            {
                                <option value="@cat.Id" selected>@cat.Name</option>
                            }
                            else
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        }
                    }
                </select>
            </div>

            <div class="col-md-4">
                <button type="submit" class="btn btn-primary"><i class="fas fa-filter"></i> Lọc dữ liệu</button>
                <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-sync"></i> Hủy lọc</a>
            </div>
        </form>
    </div>

    <div class="card-body p-0">
        <table class="table table-hover mb-0 align-middle text-center">
            <thead class="table-dark">
                <tr>
                    <th style="width: 80px;">ID</th>
                    <th style="width: 100px;">Hình ảnh</th>
                    <th class="text-start">Tên sản phẩm</th>
                    <th>Giá bán</th>
                    <th>Số lượng kho</th>
                    <th class="text-start">Danh mục sản phẩm</th>
                    <th style="width: 150px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-secondary">@item.Id</td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" alt="Product" class="img-thumbnail" style="width: 55px; height: 55px; object-fit: cover;" />
                                }
                                else
                                {
                                    <img src="https://via.placeholder.com/150?text=No+Image" alt="No Image" class="img-thumbnail" style="width: 55px; height: 55px; object-fit: cover;" />
                                }
                            </td>
                            <td class="text-start fw-bold text-dark">
                                @item.Name
                                @if (!string.IsNullOrEmpty(item.Description))
                                {
                                    <small class="d-block text-muted fw-normal text-truncate" style="max-width: 250px;" title="@item.Description">
                                        @item.Description
                                    </small>
                                }
                            </td>
                            <td class="text-danger fw-bold">@item.Price.ToString("N0") VNĐ</td>
                            <td>
                                @if (item.StockQuantity > 0)
                                {
                                    <span class="badge bg-success">@item.StockQuantity chiếc</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Hết hàng</span>
                                }
                            </td>
                            <td class="text-start text-primary fw-bold">
                                @(item.CategoryProduct != null ? item.CategoryProduct.Name : "Chưa phân loại")
                            </td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm border-0 me-1">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm border-0"
                                   onclick="return confirm('Bạn có chắc chắn muốn xóa sản phẩm này không?')">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-muted p-4">
                            <i class="fas fa-box-open fa-2x d-block mb-2"></i> Không tìm thấy sản phẩm nào phù hợp.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (ViewBag.TotalPages > 1)
    {
        <div class="card-footer bg-white d-flex justify-content-end py-3 border-top">
            <nav aria-label="Page navigation">
                <ul class="pagination mb-0">

                    <li class="page-item @(ViewBag.CurrentPage <= 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-page="@(ViewBag.CurrentPage - 1)"
                           asp-route-searchString="@ViewBag.CurrentSearch"
                           asp-route-categoryProductId="@ViewBag.CurrentCategory">
                            <i class="fas fa-chevron-left me-1"></i> Trước
                        </a>
                    </li>

                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                            <a class="page-link" asp-action="Index"
                               asp-route-page="@i"
                               asp-route-searchString="@ViewBag.CurrentSearch"
                               asp-route-categoryProductId="@ViewBag.CurrentCategory">
                                @i
                            </a>
                        </li>
                    }

                    <li class="page-item @(ViewBag.CurrentPage >= ViewBag.TotalPages ? "disabled" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-page="@(ViewBag.CurrentPage + 1)"
                           asp-route-searchString="@ViewBag.CurrentSearch"
                           asp-route-categoryProductId="@ViewBag.CurrentCategory">
                            Sau <i class="fas fa-chevron-right ms-1"></i>
                        </a>
                    </li>

                </ul>
            </nav>
        </div>
    }
</div>