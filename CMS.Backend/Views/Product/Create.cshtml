@model CMS.Data.Entities.Product

@{
    ViewData["Title"] = "Thêm sản phẩm";
}

<h2 class="text-success my-3 fw-bold">THÊM SẢN PHẨM MỚI</h2>
<hr />

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Create" enctype="multipart/form-data">
            <div class="row">
                <div class="col-md-8">
                    <div class="form-group mb-3">
                        <label class="form-label fw-bold">Tên sản phẩm</label>
                        <input asp-for="Name" class="form-control" placeholder="Nhập tên sản phẩm..." required />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label class="form-label fw-bold">Mô tả sản phẩm</label>
                        <textarea asp-for="Description" class="form-control" rows="5" placeholder="Nhập thông số kỹ thuật, cấu hình..."></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Giá bán (VNĐ)</label>
                            <input asp-for="Price" type="number" class="form-control" placeholder="0" required />
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Số lượng kho</label>
                            <input asp-for="StockQuantity" type="number" class="form-control" placeholder="0" required />
                            <span asp-validation-for="StockQuantity" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label class="form-label fw-bold">Danh mục sản phẩm</label>
                        <select asp-for="CategoryProductId" class="form-select" asp-items="ViewBag.CategoryProductId" required>
                            <option value="">-- Chọn danh mục sản phẩm --</option>
                        </select>
                        <span asp-validation-for="CategoryProductId" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label class="form-label fw-bold">Hình ảnh sản phẩm</label>
                        <input type="file" name="imageFile" class="form-control" accept="image/*" required />
                        <small class="text-muted d-block mt-1">Hệ thống chấp nhận các định dạng ảnh thông dụng (.jpg, .png)</small>
                    </div>
                </div>
            </div>

            <div class="mt-3 border-top pt-3">
                <button type="submit" class="btn btn-primary px-4 fw-bold">
                    <i class="fas fa-save me-1"></i> Lưu sản phẩm
                </button>
                <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
            </div>
        </form>
    </div>
</div>