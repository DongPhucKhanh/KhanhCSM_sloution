@model CMS.Data.Entities.Product

@{
    ViewData["Title"] = "Sửa sản phẩm phụ tùng";
}

<h2 class="text-warning my-3 fw-bold">CHỈNH SỬA THÔNG TIN SẢN PHẨM</h2>
<hr />

<div class="card shadow-sm border-0 rounded-lg">
    <div class="card-body p-4 bg-white">
        <form asp-action="Edit" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ImageUrl" />

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Tên linh kiện / Đồ chơi</label>
                    <input asp-for="Name" class="form-control" required />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Mã nhóm danh mục (ID)</label>
                    <input asp-for="CategoryProductId" type="number" class="form-control" required />
                    <span asp-validation-for="CategoryProductId" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Giá bán (VNĐ)</label>
                    <input asp-for="Price" type="number" class="form-control" required />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Số lượng tồn kho</label>
                    <input asp-for="StockQuantity" type="number" class="form-control" required />
                    <span asp-validation-for="StockQuantity" class="text-danger"></span>
                </div>
            </div>

            <div class="row align-items-center mb-3">
                <div class="col-md-8">
                    <label class="form-label fw-bold">Chọn hình ảnh từ máy tính</label>
                    <input type="file" name="ImageFile" class="form-control" accept="image/*" />
                    <small class="text-muted d-block mt-1">Nếu không chọn ảnh mới, hệ thống sẽ giữ nguyên hình ảnh cũ đang dùng.</small>
                </div>

                <div class="col-md-4 text-center mt-3 mt-md-0">
                    <label class="form-label fw-bold d-block text-secondary small">Ảnh hiện tại</label>
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" alt="Preview" class="img-thumbnail shadow-sm" style="max-height: 100px; object-fit: cover;" />
                    }
                    else
                    {
                        <div class="border rounded d-flex align-items-center justify-content-center bg-light text-muted small" style="height: 100px;">
                            Chưa có ảnh
                        </div>
                    }
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Thông số kỹ thuật / Mô tả sản phẩm</label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="mt-4 border-top pt-3">
                <button type="submit" class="btn btn-warning px-4 fw-bold text-dark rounded-pill">
                    <i class="fas fa-save me-1"></i> Lưu lại thay đổi
                </button>
                <a asp-action="Index" class="btn btn-secondary rounded-pill px-3 ml-2">Quay lại danh sách</a>
            </div>
        </form>
    </div>
</div>