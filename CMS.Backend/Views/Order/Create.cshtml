@model CMS.Data.Entities.Order

@{
    ViewData["Title"] = "Tạo đơn hàng";
}

<h2 class="text-danger my-3 fw-bold">TẠO ĐƠN HÀNG MỚI</h2>
<hr />

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Create">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Khách hàng đặt mua</label>
                    <select asp-for="CustomerId" class="form-select" asp-items="ViewBag.CustomerId" required>
                        <option value="">-- Chọn khách hàng --</option>
                    </select>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Ngày lập đơn</label>
                    <input asp-for="OrderDate" type="datetime-local" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" required />
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Trạng thái xử lý</label>
                    <select asp-for="Status" class="form-select">
                        <option value="0">Chờ duyệt</option>
                        <option value="1">Đang giao</option>
                        <option value="2">Đã xong</option>
                    </select>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Ghi chú nội bộ</label>
                    <input asp-for="Notes" class="form-control" placeholder="Nhập ghi chú đơn hàng nếu có..." />
                </div>
            </div>

            <div class="mt-3 border-top pt-3">
                <button type="submit" class="btn btn-danger px-4 fw-bold">Lưu đơn hàng</button>
                <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
            </div>
        </form>
    </div>
</div>