@model CMS.Data.Entities.Order

@{
    ViewData["Title"] = "Chỉnh sửa đơn hàng";
}

<h2 class="text-warning my-3 fw-bold">CHỈNH SỬA THÔNG TIN ĐƠN HÀNG</h2>
<hr />

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Edit">
            <input type="hidden" asp-for="Id" />

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Khách hàng</label>
                    <select asp-for="CustomerId" class="form-select" asp-items="ViewBag.CustomerId" required></select>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Ngày đặt hàng</label>
                    <input asp-for="OrderDate" type="datetime-local" class="form-control" value="@Model.OrderDate.ToString("yyyy-MM-ddTHH:mm")" required />
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Trạng thái đơn</label>
                    <select asp-for="Status" class="form-select">
                        <!option value="0" @(Model.Status == 0 ? "selected" : "")>Chờ duyệt</!option>
                        <!option value="1" @(Model.Status == 1 ? "selected" : "")>Đang giao</!option>
                        <!option value="2" @(Model.Status == 2 ? "selected" : "")>Đã xong</!option>
                    </select>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Ghi chú (Notes)</label>
                    <textarea asp-for="Notes" class="form-control" rows="1">@Model.Notes</textarea>
                </div>
            </div>

            <div class="mt-3 border-top pt-3">
                <button type="submit" class="btn btn-warning px-4 fw-bold text-dark">Cập nhật đơn hàng</button>
                <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
            </div>
        </form>
    </div>
</div>