@model IEnumerable<CMS.Data.Entities.Order>

@{
    ViewData["Title"] = "Quản lý đơn hàng";
}

<div class="card shadow-sm mt-3">
    <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
        <h4 class="text-danger fw-bold m-0">
            <i class="fas fa-shopping-cart me-2"></i>QUẢN LÝ DANH SÁCH ĐƠN HÀNG
        </h4>
        <a asp-action="Create" class="btn btn-danger btn-sm fw-bold">
            <i class="fas fa-plus-circle me-1"></i>TẠO ĐƠN THỦ CÔNG
        </a>
    </div>

    <div class="card-body p-0">
        <table class="table table-hover mb-0 align-middle text-center">
            <thead class="table-dark">
                <tr>
                    <th style="width: 80px;">Mã ĐH</th>
                    <th class="text-start">Khách hàng đặt</th>
                    <th>Ngày đặt</th>
                    <th>Trạng thái</th>
                    <th>Duyệt đơn</th>
                    <th style="width: 150px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-secondary">#@item.Id</td>
                            <td class="text-start">
                                <span class="fw-bold text-dark d-block">@(item.Customer != null ? item.Customer.FullName : "N/A")</span>
                                <small class="text-muted">@(item.Customer != null ? item.Customer.Phone : "")</small>
                            </td>
                            <td>@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                @if (item.Status == 0)
                                {
                                    <span class="badge bg-warning text-dark">Chờ duyệt</span>
                                }
                                else if (item.Status == 1)
                                {
                                    <span class="badge bg-primary">Đang giao</span>
                                }
                                else if (item.Status == 2)
                                {
                                    <span class="badge bg-success">Đã xong</span>
                                }
                            </td>
                            <td>
                                <form asp-action="UpdateStatus" asp-route-id="@item.Id" method="post" class="d-inline-flex gap-1">
                                    <select name="status" class="form-select form-select-sm" style="width: 130px;">
                                        <!option value="0" @(item.Status == 0 ? "selected" : "")>Chờ duyệt</!option>
                                        <!option value="1" @(item.Status == 1 ? "selected" : "")>Đang giao</!option>
                                        <!option value="2" @(item.Status == 2 ? "selected" : "")>Đã xong</!option>
                                    </select>
                                    <button type="submit" class="btn btn-sm btn-secondary">Lưu</button>
                                </form>
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info btn-sm border-0 me-1">
                                    <i class="fas fa-eye"></i> Xem
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm border-0"
                                   onclick="return confirm('Bạn có chắc chắn muốn xóa đơn hàng này?')">
                                    <i class="fas fa-trash-alt"></i> Xóa
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-muted p-4">Không có đơn hàng nào trong hệ thống.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>