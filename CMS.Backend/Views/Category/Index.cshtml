@model IEnumerable<CMS.Data.Entities.Category>

<div class="d-flex justify-content-between align-items-center my-3">
    <h2 class="text-primary m-0">DANH SÁCH DANH MỤC</h2>
    <a asp-action="Create" class="btn btn-success">Thêm danh mục mới</a>
</div>

<table class="table table-bordered table-striped">
    <thead>
        <tr class="table-dark">
            <th>ID</th>
            <th>Tên danh mục</th>
            <th>Mô tả</th>
            <th class="text-center" style="width: 150px;">Chức năng</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Name</td>
                <td>@item.Description</td>
                <td class="text-center">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Sửa</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm"
                       onclick="return confirm('Bạn có chắc chắn muốn xóa danh mục này không?')">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>