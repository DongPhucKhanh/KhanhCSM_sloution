@model CMS.Data.Entities.CategoryProduct

@{
    ViewData["Title"] = "Sửa danh mục sản phẩm";
}

<h2 class="text-warning my-3 fw-bold">CHỈNH SỬA DANH MỤC SẢN PHẨM</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-action="Edit">
                    <input type="hidden" asp-for="Id" />

                    <div class="form-group mb-3">
                        <label class="form-label fw-bold">Tên danh mục sản phẩm</label>
                        <input asp-for="Name" class="form-control" required />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label class="form-label fw-bold">Mô tả danh mục</label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="form-group mt-4">
                        <button type="submit" class="btn btn-warning fw-bold text-dark px-4">
                            <i class="fas fa-edit me-1"></i> Cập nhật thay đổi
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>