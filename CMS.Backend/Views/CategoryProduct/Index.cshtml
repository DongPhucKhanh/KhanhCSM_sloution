@model IEnumerable<CMS.Data.Entities.CategoryProduct>

@{
    ViewData["Title"] = "Danh mục sản phẩm";
}

<div class="card shadow-sm mt-3">
    <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
        <h4 class="text-success fw-bold m-0">
            <i class="fas fa-boxes me-2"></i>QUẢN LÝ DANH MỤC SẢN PHẨM
        </h4>
        <a asp-action="Create" class="btn btn-success btn-sm fw-bold">
            <i class="fas fa-plus-circle me-1"></i>THÊM DANH MỤC MỚI
        </a>
    </div>

    <div class="card-body p-0">
        <table class="table table-hover mb-0 align-middle text-center">
            <thead class="table-dark">
                <tr>
                    <th style="width: 100px;">Mã số (ID)</th>
                    <th class="text-start">Tên danh mục sản phẩm</th>
                    <th style="width: 180px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-secondary">@item.Id</td>
                            <td class="text-start fw-bold text-dark">@item.Name</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm border-0 me-1">
                                    <i class="fas fa-edit"></i> Sửa
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm border-0"
                                   onclick="return confirm('Xóa danh mục này có thể ảnh hưởng đến các sản phẩm bên trong. Bạn chắc chắn muốn xóa?')">
                                    <i class="fas fa-trash"></i> Xóa
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="text-muted p-4">
                            <i class="fas fa-folder-open fa-2x d-block mb-2"></i>
                            Chưa có danh mục sản phẩm nào. Ấn "Thêm mới" để tạo.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>