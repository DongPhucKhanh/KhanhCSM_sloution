@model IEnumerable<CMS.Data.Entities.User>
@{
    ViewData["Title"] = "Quản lý thành viên";
}

<div class="card shadow-sm mt-3">
    <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
        <h4 class="text-dark fw-bold m-0">
            <i class="fas fa-users-cog me-2"></i>QUẢN LÝ THÀNH VIÊN HỆ THỐNG
        </h4>
        <a asp-action="Create" class="btn btn-success btn-sm fw-bold">
            <i class="fas fa-plus-circle me-1"></i>THÊM THÀNH VIÊN MỚI
        </a>
    </div>

    <div class="card-body p-0">
        <table class="table table-hover mb-0 align-middle text-center">
            <thead class="table-dark">
                <tr>
                    <th style="width: 80px;">ID</th>
                    <th>Tên Đăng Nhập</th>
                    <th>Họ và Tên</th>
                    <th>Email</th>
                    <th>Quyền Hạn</th>
                    <th>Trạng Thái</th>
                    <th style="width: 180px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var user in Model)
                    {
                        <tr>
                            <td>@user.Id</td>
                            <td><strong>@user.Username</strong></td>
                            <td>@user.FullName</td>
                            <td>@user.Email</td>
                            <td>
                                @if (user.Role == "Admin")
                                {
                                    <span class="badge bg-danger">@user.Role</span>
                                }
                                else
                                {
                                    <span class="badge bg-info text-dark">@user.Role</span>
                                }
                            </td>
                            <td>
                                @if (user.IsActive)
                                {
                                    <span class="badge bg-success">Hoạt động</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Khóa</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-outline-warning btn-sm me-1">
                                    <i class="fas fa-edit"></i> Sửa
                                </a>
                                <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-outline-danger btn-sm"
                                   onclick="return confirm('Bạn có chắc chắn muốn xóa thành viên @user.Username không?')">
                                    <i class="fas fa-trash-alt"></i> Xóa
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-muted p-4">Không có thành viên nào trong hệ thống.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>