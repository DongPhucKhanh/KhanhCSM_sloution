@model IEnumerable<CMS.Data.Entities.User>

<div class="container mt-4">
    <h2 class="mb-4 text-success text-center fw-bold">QUẢN LÝ DANH SÁCH NGƯỜI DÙNG</h2>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-bordered table-striped align-middle mb-0">
            <thead class="table-success text-dark">
                <tr>
                    <th style="width: 80px;">ID</th>
                    <th>Tài khoản</th>
                    <th>Họ và tên</th>
                    <th>Email</th>
                    <th>Quyền quản trị</th>
                    <th class="text-center">Trạng thái</th>
                    <th>Ngày tạo</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null)
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-secondary">@item.Id</td>
                            <td class="fw-bold">@item.Username</td>
                            <td>@item.FullName</td>
                            <td>@item.Email</td>
                            <td>
                                @if (item.Role == "Administrator")
                                {
                                    <span class="badge bg-danger">@item.Role</span>
                                }
                                else if (item.Role == "Editor")
                                {
                                    <span class="badge bg-warning text-dark">@item.Role</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@item.Role</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success rounded-pill"><i class="bi bi-check-circle"></i> Đang hoạt động</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger rounded-pill"><i class="bi bi-x-circle"></i> Đang khóa</span>
                                }
                            </td>
                            <td class="text-muted small">@item.CreatedDate.ToString("dd/MM/yyyy")</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>