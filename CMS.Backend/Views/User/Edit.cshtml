@model CMS.Data.Entities.User

@{
    ViewData["Title"] = "Chỉnh sửa người dùng";
}

<div class="container mt-4">
    <h2 class="text-warning fw-bold my-3">CHỈNH SỬA THÔNG TIN NGƯỜI DÙNG</h2>
    <hr />

    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <form asp-action="Edit">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="CreatedDate" />

                        <div class="form-group mb-3">
                            <label class="form-label fw-bold">Tên tài khoản (Không được đổi)</label>
                            <input asp-for="Username" class="form-control bg-light" readonly />
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label fw-bold">Họ và tên người dùng</label>
                            <input asp-for="FullName" class="form-control" required />
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label fw-bold">Địa chỉ Email</label>
                            <input asp-for="Email" type="email" class="form-control" required />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Mật khẩu mới (Bỏ trống nếu giữ nguyên mật khẩu cũ)</label>
                            <input asp-for="Password" type="password" class="form-control" placeholder="Nhập mật khẩu mới tại đây..." />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label fw-bold">Quyền quản trị (Role)</label>
                            <select asp-for="Role" class="form-select" required>
                                <option value="Administrator">Administrator</option>
                                <option value="Editor">Editor</option>
                                <option value="Viewer">Viewer</option>
                            </select>
                            <span asp-validation-for="Role" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label fw-bold d-block">Trạng thái hoạt động</label>
                            <div class="form-check form-switch fs-5">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                                <label class="form-check-label small text-muted">Bật / Tắt kích hoạt tài khoản</label>
                            </div>
                        </div>

                        <div class="form-group mt-4">
                            <button type="submit" class="btn btn-warning fw-bold text-dark">
                                <i class="fas fa-edit"></i> Cập nhật thay đổi
                            </button>
                            <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>