@model CMS.Data.Entities.User
@{
    ViewData["Title"] = "Cập nhật thành viên";
}

<h2 class="text-warning my-3 fw-bold">CẬP NHẬT THÔNG TIN THÀNH VIÊN</h2>
<hr />

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="fw-bold form-label">Tên đăng nhập (Username):</label>
                    <input asp-for="Username" class="form-control bg-light" readonly />
                    <small class="text-muted">Tên đăng nhập không được phép sửa.</small>
                </div>
                <div class="col-md-6">
                    <label class="fw-bold form-label">Mật khẩu mới (Nếu muốn đổi):</label>
                    <input type="password" name="NewPassword" class="form-control" placeholder="Để trống nếu muốn giữ nguyên mật khẩu cũ..." />
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="fw-bold form-label">Họ và Tên:</label>
                    <input asp-for="FullName" class="form-control" required />
                    <span asp-validation-for="FullName" class="text-danger small fw-bold"></span>
                </div>
                <div class="col-md-6">
                    <label class="fw-bold form-label">Địa chỉ Email:</label>
                    <input asp-for="Email" class="form-control" required />
                    <span asp-validation-for="Email" class="text-danger small fw-bold"></span>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="fw-bold form-label">Vai trò (Role):</label>
                    <select asp-for="Role" class="form-select">
                        <option value="Admin">Admin</option>
                        <option value="Editor">Editor</option>
                    </select>
                    <span asp-validation-for="Role" class="text-danger small fw-bold"></span>
                </div>
                <div class="col-md-6">
                    <label class="fw-bold form-label">Trạng thái tài khoản</label>
                    <div class="form-check form-switch mt-2">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label class="form-check-label text-muted">Kích hoạt</label>
                    </div>
                </div>
            </div>

            <div class="mt-3 border-top pt-3">
                <button type="submit" class="btn btn-warning px-4 fw-bold text-dark">Cập nhật tài khoản</button>
                <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
            </div>
        </form>
    </div>
</div>