@* Chức năng: Giao diện khung hệ thống quản trị chuyên nghiệp (Layout Admin) *@
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CMS.Backend</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CMS.Backend.styles.css" asp-append-version="true" />
</head>
<body>

    <div id="wrapper" class="d-flex">
        <nav id="sidebar" class="bg-dark text-white min-vh-100" style="width: 250px;">
            <div class="sidebar-header p-3 border-bottom border-secondary text-center">
                <h3 class="m-0 text-info fw-bold">CMS TIN TỨC</h3>
            </div>

            <div class="section-header px-3 pt-3 pb-1 text-muted small text-uppercase fw-bold">Quản trị hệ thống</div>

            <ul class="list-unstyled components px-2">
                <li class="mb-1">
                    <a asp-controller="Home" asp-action="Index" class="nav-link text-white p-2 rounded d-flex align-items-center">
                        <i class="fas fa-home me-2" style="width: 20px;"></i> Trang chủ
                    </a>
                </li>
                <li class="mb-1">
                    <a asp-controller="CategoryProduct" asp-action="Index" class="nav-link text-white p-2 rounded d-flex align-items-center">
                        <i class="fas fa-boxes me-2" style="width: 20px;"></i> Danh mục sản phẩm
                    </a>
                </li>
                <li class="mb-1">
                    <a asp-controller="Product" asp-action="Index" class="nav-link text-white p-2 rounded d-flex align-items-center">
                        <i class="fas fa-cube me-2" style="width: 20px;"></i> Quản lý sản phẩm
                    </a>
                </li>
                <li class="mb-1">
                    <a asp-controller="Category" asp-action="Index" class="nav-link text-white p-2 rounded d-flex align-items-center">
                        <i class="fas fa-list me-2" style="width: 20px;"></i> Danh mục bài viết
                    </a>
                </li>
                <li class="mb-1">
                    <a asp-controller="Post" asp-action="Index" class="nav-link text-white p-2 rounded d-flex align-items-center">
                        <i class="fas fa-edit me-2" style="width: 20px;"></i> Quản lý bài viết
                    </a>
                </li>
                <li class="mb-1">
                    <a asp-controller="User" asp-action="Index" class="nav-link text-white p-2 rounded d-flex align-items-center">
                        <i class="fas fa-users-cog me-2" style="width: 20px;"></i> Quản lý người dùng
                    </a>
                </li>
                <li class="mb-1">
                    <a asp-controller="Customer" asp-action="Index" class="nav-link text-white p-2 rounded d-flex align-items-center">
                        <i class="fas fa-users me-2" style="width: 20px;"></i> Quản lý khách hàng
                    </a>
                </li>
                <li class="mb-1">
                    <a asp-controller="Order" asp-action="Index" class="nav-link text-white p-2 rounded d-flex align-items-center">
                        <i class="fas fa-receipt me-2" style="width: 20px;"></i> Quản lý đơn hàng
                    </a>
                </li>
            </ul>

            <hr class="mx-3 my-2 border-secondary" />

            <ul class="list-unstyled px-2 mb-0">
                <li class="logout-link">
                    <a href="#" class="nav-link text-danger p-2 rounded d-flex align-items-center fw-bold">
                        <i class="fas fa-sign-out-alt me-2" style="width: 20px;"></i> Đăng xuất hệ thống
                    </a>
                </li>
            </ul>
        </nav>

        <div id="content" class="flex-grow-1 bg-light">
            <header>
                <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow p-3">
                    <div class="container-fluid p-0">
                        <button type="button" id="sidebarCollapse" class="btn btn-dark btn-sm me-3">
                            <i class="fas fa-bars"></i>
                        </button>
                        <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                            <ul class="navbar-nav flex-grow-1">
                                <li class="nav-item">
                                    <a class="nav-link text-dark fw-bold" asp-controller="Home" asp-action="Index">Hệ thống Admin</a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </nav>
            </header>

            <div class="container-fluid px-4 py-3">
                <main role="main" class="pb-3">
                    @RenderBody()
                </main>
            </div>

            <footer class="border-top footer text-muted bg-white py-3 mt-auto">
                <div class="container-fluid px-4">
                    &copy; 2026 - CMS.Backend - <a asp-controller="Home" asp-action="Privacy">Privacy</a>
                </div>
            </footer>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>